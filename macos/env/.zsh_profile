export XDG_CONFIG_HOME=$HOME/.config
VIM=nvim
PERSONAL=$XDG_CONFIG_HOME/personal

bindkey -s ^f "tmux-sessionizer\n"

source $PERSONAL/env
source $PERSONAL/alias
source $PERSONAL/paths

fzf_dir=/opt/homebrew/opt/fzf/shell
if [ -d $fzf_dir ]; then
    source $fzf_dir/key-bindings.zsh
    source $fzf_dir/completion.zsh
fi

addToPathFront $HOME/.local/scripts
addToPathFront $HOME/.local/bin
addToPathFront /opt/homebrew/bin/brew

tmux=$(which tmux)
alias tmux="$tmux -2"

alias mlx="mlx_lm.server --port 8080"

export ANDROID_HOME=$HOME/Library/Android/sdk

addToPathFront $ANDROID_HOME/platform-tools
addToPathFront $ANDROID_HOME/emulator
addToPathFront $ANDROID_HOME/cmdline-tools/latest/bin

_robocop_completion() {
  eval $(env _TYPER_COMPLETE_ARGS="${words[1,$CURRENT]}" _ROBOCOP_COMPLETE=complete_zsh robocop)
}

compdef _robocop_completion robocop
