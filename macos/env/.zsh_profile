export XDG_CONFIG_HOME=$HOME/.config
VIM=nvim
PERSONAL=$XDG_CONFIG_HOME/personal

bindkey -s ^f "tmux-sessionizer\n"

source $PERSONAL/env
for i in `find -L $PERSONAL`; do
    source $i
done

fzf_dir=`ls -d /opt/homebrew/Cellar/fzf/* | head -n 1`/shell
if [ -d $fzf_dir ]; then
    source $fzf_dir/key-bindings.zsh
    source $fzf_dir/completion.zsh
fi

addToPathFront $HOME/.local/scripts
addToPathFront $HOME/.local/bin
addToPathFront /opt/homebrew/bin/brew

tmux=$(which tmux)
alias tmux="$tmux -2"

_robocop_completion() {
  eval $(env _TYPER_COMPLETE_ARGS="${words[1,$CURRENT]}" _ROBOCOP_COMPLETE=complete_zsh robocop)
}

compdef _robocop_completion robocop
