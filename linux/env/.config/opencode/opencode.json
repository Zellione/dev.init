{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "mode": {
    "plan": {
      "model": "opencode-go/kimi-k2.6"
    },
    "build": {
      "model": "opencode-go/deepseek-v4-pro"
    }
  },
  "provider": {
    "local-wsl-llama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local WSL Llama",
      "options": {
        "baseURL": "http://127.0.0.1:8001/v1"
      },
      "models": {
        "qwen36-27b": {
          "tools": true,
	  "limit": {
		"context": 64000,
		"output": 4096
	  }
        },
        "qwen36-35b-a3b": {
          "tools": true,
	  "limit": {
		"context": 262144,
		"output": 8192
	  }
        },
        "qwen25-coder-14b-instruct": {
          "tools": true,
	  "limit": {
		"context": 32768,
		"output": 4096
	  }
        }
      }
    }
  },
  "model": "qwen36-27b"
}
